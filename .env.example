# Copy this file to ".env" and paste your Anthropic API key below.
# Get a key at: https://console.anthropic.com/  (Settings → API Keys)
# Keep .env private — it is git-ignored and must NEVER be committed.

ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: change the port the site runs on (default 3000)
# PORT=3000
